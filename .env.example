# Google OAuth (Web application client из Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js (генерится: openssl rand -base64 32)
AUTH_SECRET=

# Trust proxy headers (нужно для cloudflared/прод)
AUTH_TRUST_HOST=true

# Optional: путь к SQLite-файлу (по умолчанию ./data/gsc-hub.db)
# DB_PATH=./data/gsc-hub.db
